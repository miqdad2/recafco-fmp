{
  "name": "recafco-fmp",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "lint": "eslint .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "dev": "turbo dev",
    "db:validate": "pnpm --filter @recafco/database run db:validate",
    "db:format": "pnpm --filter @recafco/database run db:format",
    "db:generate": "pnpm --filter @recafco/database run db:generate",
    "db:migrate:dev": "pnpm --filter @recafco/database run db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @recafco/database run db:migrate:deploy",
    "db:migrate:status": "pnpm --filter @recafco/database run db:migrate:status",
    "db:studio": "pnpm --filter @recafco/database run db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
