NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
LOG_LEVEL=info
API_BASE_URL=http://localhost:4000
CORS_ALLOWED_ORIGINS=http://localhost:3000
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_STALE_AFTER_MS=60000

# PostgreSQL connection URL
# Use the recafco_fmp_app role (not the postgres superuser) for local development.
# Databases: recafco_fmp_dev (development), recafco_fmp_test (automated tests only).
DATABASE_URL=postgresql://recafco_fmp_app:change_me@localhost:5432/recafco_fmp_dev?schema=public

# Optional: override connection pool defaults
# DATABASE_CONNECTION_TIMEOUT_MS=10000
# DATABASE_STATEMENT_TIMEOUT_MS=30000
# DATABASE_POOL_MAX=10

# JWT signing secret — must be at least 32 characters, random, and kept secret.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change_me_generate_a_random_secret_at_least_32_chars

# Optional: override JWT/session expiry defaults
# JWT_ACCESS_EXPIRES_SECONDS=900
# REFRESH_TOKEN_EXPIRES_DAYS=7

# Optional: override lockout policy defaults
# MAX_FAILED_LOGIN_ATTEMPTS=10
# LOCKOUT_WINDOW_MINUTES=15
