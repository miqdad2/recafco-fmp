{
  "name": "@recafco/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --env-file=../../.env -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bootstrap:admin": "node --env-file=../../.env -r ts-node/register -r tsconfig-paths/register src/scripts/bootstrap-admin.ts",
    "cleanup:sessions": "node --env-file=../../.env -r ts-node/register -r tsconfig-paths/register src/scripts/cleanup-sessions.ts",
    "uat:seed": "node --env-file=../../.env -r ts-node/register -r tsconfig-paths/register src/scripts/uat-seed.ts",
    "uat:cleanup": "node --env-file=../../.env -r ts-node/register -r tsconfig-paths/register src/scripts/uat-cleanup.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.0",
    "@node-rs/argon2": "^2.0.2",
    "@recafco/config": "workspace:*",
    "@recafco/database": "workspace:*",
    "@recafco/observability": "workspace:*",
    "@recafco/shared": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
