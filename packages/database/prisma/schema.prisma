// RECAFCO FMP — Prisma Schema
// Managed by packages/database. Do not instantiate PrismaClient outside this package.
// Domain models will be added in later units when real requirements are confirmed.
// Never run prisma migrate reset against any company database.
//
// Prisma 7: connection URL lives in prisma.config.ts (not here).
// Runtime connection uses PrismaPg adapter passed to PrismaClient constructor.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
