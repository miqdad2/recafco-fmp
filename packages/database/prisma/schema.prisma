// ---------------------------------------------------------------------------
// Maintenance Requests Foundation
// Unit 10 — added 2026-07-01
//
// Status lifecycle: DRAFT → SUBMITTED → UNDER_REVIEW → APPROVED → ASSIGNED
//   → IN_PROGRESS ⇆ WAITING_FOR_PARTS → COMPLETED → CLOSED.
//   REJECTED is terminal from UNDER_REVIEW. CANCELLED is terminal from most
//   open states (DRAFT through WAITING_FOR_PARTS).
//   COMPLETED/CLOSED may be reopened to IN_PROGRESS by maintenance.manage.
//
// Reference numbers are MR-YYYY-NNNNNN generated atomically via
//   MaintenanceSequence upsert inside the creation transaction (UTC year).
//   Sequence CHECK: last_seq BETWEEN 0 AND 999999.
//
// onDelete: Restrict on createdByUser and child history tables to keep
//   history intact. SetNull on all nullable FK columns.
//
// actorUserId in MaintenanceRequestActivity has no FK — mirrors IncidentActivity.
//   actorName is denormalized to preserve history when users are deactivated.
//
// Assignee ownership rule: start/waitForParts/resume/complete require
//   assignedToUserId = actor.id unless actor has maintenance.manage.
// ---------------------------------------------------------------------------

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT

  @@map("maintenance_priority")
}

enum MaintenanceStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  ASSIGNED
  IN_PROGRESS
  WAITING_FOR_PARTS
  COMPLETED
  CLOSED
  REJECTED
  CANCELLED

  @@map("maintenance_status")
}

model MaintenanceSequence {
  year    Int @id
  lastSeq Int @default(0) @map("last_seq")

  @@map("maintenance_sequences")
}

model MaintenanceRequest {
  id                    String              @id @default(uuid()) @db.Uuid
  referenceNumber       String              @unique @map("reference_number") @db.VarChar(20)
  title                 String              @db.VarChar(300)
  problemDescription    String              @map("problem_description") @db.VarChar(10000)
  priority              MaintenancePriority @default(MEDIUM)
  status                MaintenanceStatus   @default(DRAFT)
  createdByUserId       String              @map("created_by_user_id") @db.Uuid
  requestedByUserId     String?             @map("requested_by_user_id") @db.Uuid
  assignedToUserId      String?             @map("assigned_to_user_id") @db.Uuid
  affectedDepartmentId  String?             @map("affected_department_id") @db.Uuid
  plantId               String?             @map("plant_id") @db.Uuid
  locationId            String?             @map("location_id") @db.Uuid
  equipmentDescription  String?             @map("equipment_description") @db.VarChar(1000)
  requestedCompletionAt DateTime?           @map("requested_completion_at") @db.Timestamptz(3)
  startedAt             DateTime?           @map("started_at") @db.Timestamptz(3)
  waitingForPartsAt     DateTime?           @map("waiting_for_parts_at") @db.Timestamptz(3)
  waitingForPartsReason String?             @map("waiting_for_parts_reason") @db.VarChar(2000)
  completedAt           DateTime?           @map("completed_at") @db.Timestamptz(3)
  completedByUserId     String?             @map("completed_by_user_id") @db.Uuid
  completionSummary     String?             @map("completion_summary") @db.VarChar(4000)
  closedAt              DateTime?           @map("closed_at") @db.Timestamptz(3)
  closedByUserId        String?             @map("closed_by_user_id") @db.Uuid
  rejectedAt            DateTime?           @map("rejected_at") @db.Timestamptz(3)
  rejectedByUserId      String?             @map("rejected_by_user_id") @db.Uuid
  rejectionReason       String?             @map("rejection_reason") @db.VarChar(1000)
  cancelledAt           DateTime?           @map("cancelled_at") @db.Timestamptz(3)
  cancelledByUserId     String?             @map("cancelled_by_user_id") @db.Uuid
  cancellationReason    String?             @map("cancellation_reason") @db.VarChar(1000)
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  createdByUser      User        @relation("MRCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  requestedByUser    User?       @relation("MRRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  assignedToUser     User?       @relation("MRAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  completedByUser    User?       @relation("MRCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  closedByUser       User?       @relation("MRClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  rejectedByUser     User?       @relation("MRRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  cancelledByUser    User?       @relation("MRCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  affectedDepartment Department? @relation(fields: [affectedDepartmentId], references: [id], onDelete: SetNull)
  plant              Plant?      @relation(fields: [plantId], references: [id], onDelete: SetNull)
  location           Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)

  comments   MaintenanceRequestComment[]
  activities MaintenanceRequestActivity[]

  @@index([status, createdAt(sort: Desc)])
  @@index([priority, status])
  @@index([assignedToUserId, status])
  @@index([createdByUserId])
  @@index([affectedDepartmentId])
  @@index([plantId])
  @@index([requestedCompletionAt])
  @@map("maintenance_requests")
}

model MaintenanceRequestComment {
  id           String   @id @default(uuid()) @db.Uuid
  requestId    String   @map("request_id") @db.Uuid
  authorUserId String   @map("author_user_id") @db.Uuid
  body         String   @db.VarChar(5000)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  request    MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Restrict)
  authorUser User               @relation("MRCommentAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([requestId, createdAt(sort: Asc)])
  @@map("maintenance_request_comments")
}

// actorUserId has no FK — mirrors IncidentActivity; deactivating a user
// does not corrupt the maintenance request timeline.
model MaintenanceRequestActivity {
  id             String             @id @default(uuid()) @db.Uuid
  requestId      String             @map("request_id") @db.Uuid
  actorUserId    String?            @map("actor_user_id") @db.Uuid
  actorName      String?            @map("actor_name") @db.VarChar(200)
  event          String             @db.VarChar(100)
  previousStatus MaintenanceStatus? @map("previous_status")
  newStatus      MaintenanceStatus? @map("new_status")
  metadata       Json?              @db.JsonB
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)

  request MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Restrict)

  @@index([requestId, createdAt(sort: Asc)])
  @@map("maintenance_request_activities")
}

// ---------------------------------------------------------------------------
// Safety & Compliance Foundation
// Unit 11 — added 2026-07-01
//
// Status lifecycle: DRAFT → SCHEDULED → IN_PROGRESS → COMPLETED → CLOSED.
//   CANCELLED is terminal from DRAFT, SCHEDULED, or IN_PROGRESS.
//   CLOSED may be reopened to IN_PROGRESS by safety.manage.
//
// Reference numbers are SAFE-YYYY-NNNNNN generated atomically via
//   SafetyInspectionSequence upsert inside the creation transaction (UTC year).
//   Sequence CHECK: last_seq BETWEEN 0 AND 999999.
//
// Findings have their own 5-state lifecycle: OPEN → ACTION_REQUIRED | RESOLVED
//   → VERIFIED → CLOSED. RESOLVED/VERIFIED/CLOSED may be reopened to
//   ACTION_REQUIRED by safety.manage.
//
// onDelete: Restrict on createdByUser and all child history tables.
//   SetNull on nullable lifecycle user FKs.
//
// actorUserId in SafetyInspectionActivity has no FK — mirrors IncidentActivity.
//   actorName is denormalized to preserve history when users are deactivated.
//
// Inspector ownership rule: start/complete require inspectorUserId = actor.id
//   unless actor has safety.manage.
// Verifier separation-of-duties: verifiedByUserId cannot equal resolvedByUserId
//   unless actor has safety.manage.
// ---------------------------------------------------------------------------

enum InspectionStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CLOSED
  CANCELLED

  @@map("inspection_status")
}

enum FindingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("finding_severity")
}

enum FindingStatus {
  OPEN
  ACTION_REQUIRED
  RESOLVED
  VERIFIED
  CLOSED

  @@map("finding_status")
}

model SafetyInspectionSequence {
  year    Int @id
  lastSeq Int @default(0) @map("last_seq")

  @@map("safety_inspection_sequences")
}

model SafetyInspection {
  id                 String           @id @default(uuid()) @db.Uuid
  referenceNumber    String           @unique @map("reference_number") @db.VarChar(20)
  title              String           @db.VarChar(300)
  summary            String?          @db.VarChar(10000)
  status             InspectionStatus @default(DRAFT)
  scheduledAt        DateTime?        @map("scheduled_at") @db.Timestamptz(3)
  startedAt          DateTime?        @map("started_at") @db.Timestamptz(3)
  completedAt        DateTime?        @map("completed_at") @db.Timestamptz(3)
  completedByUserId  String?          @map("completed_by_user_id") @db.Uuid
  closedAt           DateTime?        @map("closed_at") @db.Timestamptz(3)
  closedByUserId     String?          @map("closed_by_user_id") @db.Uuid
  cancelledAt        DateTime?        @map("cancelled_at") @db.Timestamptz(3)
  cancelledByUserId  String?          @map("cancelled_by_user_id") @db.Uuid
  cancellationReason String?          @map("cancellation_reason") @db.VarChar(1000)
  createdByUserId    String           @map("created_by_user_id") @db.Uuid
  inspectorUserId    String?          @map("inspector_user_id") @db.Uuid
  departmentId       String?          @map("department_id") @db.Uuid
  plantId            String?          @map("plant_id") @db.Uuid
  locationId         String?          @map("location_id") @db.Uuid
  checklistSummary   String?          @map("checklist_summary") @db.VarChar(10000)
  conclusion         String?          @db.VarChar(10000)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  createdByUser   User        @relation("SafetyCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  inspector       User?       @relation("SafetyInspector", fields: [inspectorUserId], references: [id], onDelete: SetNull)
  completedByUser User?       @relation("SafetyCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  closedByUser    User?       @relation("SafetyClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  cancelledByUser User?       @relation("SafetyCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  department      Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  plant           Plant?      @relation(fields: [plantId], references: [id], onDelete: SetNull)
  location        Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)

  findings   SafetyFinding[]
  comments   SafetyInspectionComment[]
  activities SafetyInspectionActivity[]

  @@index([status, createdAt(sort: Desc)])
  @@index([inspectorUserId, status])
  @@index([createdByUserId])
  @@index([departmentId])
  @@index([plantId])
  @@index([scheduledAt])
  @@map("safety_inspections")
}

model SafetyFinding {
  id                String         @id @default(uuid()) @db.Uuid
  inspectionId      String         @map("inspection_id") @db.Uuid
  title             String         @db.VarChar(300)
  description       String         @db.VarChar(10000)
  severity          FindingSeverity
  status            FindingStatus  @default(OPEN)
  assignedToUserId  String?        @map("assigned_to_user_id") @db.Uuid
  dueAt             DateTime?      @map("due_at") @db.Timestamptz(3)
  actionRequired    String?        @map("action_required") @db.VarChar(5000)
  resolutionSummary String?        @map("resolution_summary") @db.VarChar(10000)
  resolvedAt        DateTime?      @map("resolved_at") @db.Timestamptz(3)
  resolvedByUserId  String?        @map("resolved_by_user_id") @db.Uuid
  verifiedAt        DateTime?      @map("verified_at") @db.Timestamptz(3)
  verifiedByUserId  String?        @map("verified_by_user_id") @db.Uuid
  closedAt          DateTime?      @map("closed_at") @db.Timestamptz(3)
  closedByUserId    String?        @map("closed_by_user_id") @db.Uuid
  reopenedAt        DateTime?      @map("reopened_at") @db.Timestamptz(3)
  reopenedByUserId  String?        @map("reopened_by_user_id") @db.Uuid
  reopenReason      String?        @map("reopen_reason") @db.VarChar(1000)
  createdByUserId   String         @map("created_by_user_id") @db.Uuid
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  inspection     SafetyInspection @relation(fields: [inspectionId], references: [id], onDelete: Restrict)
  createdByUser  User             @relation("FindingCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignedToUser User?            @relation("FindingAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  resolvedByUser User?            @relation("FindingResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  verifiedByUser User?            @relation("FindingVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  closedByUser   User?            @relation("FindingClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  reopenedByUser User?            @relation("FindingReopenedBy", fields: [reopenedByUserId], references: [id], onDelete: SetNull)

  @@index([inspectionId, status])
  @@index([severity, status])
  @@index([assignedToUserId, status])
  @@index([dueAt, status])
  @@map("safety_findings")
}

model SafetyInspectionComment {
  id           String   @id @default(uuid()) @db.Uuid
  inspectionId String   @map("inspection_id") @db.Uuid
  authorUserId String   @map("author_user_id") @db.Uuid
  body         String   @db.VarChar(5000)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  inspection SafetyInspection @relation(fields: [inspectionId], references: [id], onDelete: Restrict)
  authorUser User             @relation("SafetyCommentAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([inspectionId, createdAt(sort: Asc)])
  @@map("safety_inspection_comments")
}

// actorUserId has no FK — mirrors IncidentActivity; deactivating a user
// does not corrupt the inspection timeline.
model SafetyInspectionActivity {
  id             String            @id @default(uuid()) @db.Uuid
  inspectionId   String            @map("inspection_id") @db.Uuid
  actorUserId    String?           @map("actor_user_id") @db.Uuid
  actorName      String?           @map("actor_name") @db.VarChar(200)
  event          String            @db.VarChar(100)
  previousStatus InspectionStatus? @map("previous_status")
  newStatus      InspectionStatus? @map("new_status")
  metadata       Json?             @db.JsonB
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  inspection SafetyInspection @relation(fields: [inspectionId], references: [id], onDelete: Restrict)

  @@index([inspectionId, createdAt(sort: Asc)])
  @@map("safety_inspection_activities")
}

// ---------------------------------------------------------------------------
// Contracts Management Foundation
// Unit 12 — added 2026-07-01
//
// Stored status lifecycle: DRAFT → ACTIVE → TERMINATED | CLOSED
// Derived display states (computed server-side, no background job):
//   EXPIRING = stored ACTIVE + renewalNoticeDate ≤ today ≤ endDate
//   EXPIRED  = stored ACTIVE + endDate < today
//
// Reference numbers are CONTRACT-YYYY-NNNNNN generated atomically via
//   ContractSequence upsert inside the creation transaction (UTC year).
//   Sequence CHECK: last_seq BETWEEN 0 AND 999999.
//
// Optimistic concurrency: every mutating transition increments version.
//   updateMany(WHERE id AND status AND version) + count check → CONTRACT_VERSION_CONFLICT.
//
// onDelete: Restrict on ownerUser, createdByUser, and all child history tables.
//   SetNull on nullable lifecycle user FKs.
//
// actorUserId in ContractActivity has no FK — mirrors IncidentActivity.
//   actorName is denormalized to preserve history when users are deactivated.
// ---------------------------------------------------------------------------

enum ContractStatus {
  DRAFT
  ACTIVE
  TERMINATED
  CLOSED

  @@map("contract_status")
}

model ContractSequence {
  year    Int @id
  lastSeq Int @default(0) @map("last_seq")

  @@map("contract_sequences")
}

model Contract {
  id                  String         @id @default(uuid()) @db.Uuid
  referenceNumber     String         @unique @map("reference_number") @db.VarChar(25)
  title               String         @db.VarChar(300)
  description         String?        @db.Text
  status              ContractStatus @default(DRAFT)
  version             Int            @default(1)
  counterpartyName    String         @map("counterparty_name") @db.VarChar(300)
  counterpartyContact String?        @map("counterparty_contact") @db.VarChar(500)
  contractValue       Decimal?       @map("contract_value") @db.Decimal(18, 2)
  currency            String?        @db.VarChar(3)
  startDate           DateTime?      @map("start_date") @db.Date
  endDate             DateTime?      @map("end_date") @db.Date
  renewalNoticeDate   DateTime?      @map("renewal_notice_date") @db.Date
  ownerUserId         String         @map("owner_user_id") @db.Uuid
  departmentId        String?        @map("department_id") @db.Uuid
  plantId             String?        @map("plant_id") @db.Uuid
  locationId          String?        @map("location_id") @db.Uuid
  notes               String?        @db.Text
  createdByUserId     String         @map("created_by_user_id") @db.Uuid
  activatedAt         DateTime?      @map("activated_at") @db.Timestamptz(3)
  activatedByUserId   String?        @map("activated_by_user_id") @db.Uuid
  terminatedAt        DateTime?      @map("terminated_at") @db.Timestamptz(3)
  terminatedByUserId  String?        @map("terminated_by_user_id") @db.Uuid
  terminationReason   String?        @map("termination_reason") @db.VarChar(1000)
  closedAt            DateTime?      @map("closed_at") @db.Timestamptz(3)
  closedByUserId      String?        @map("closed_by_user_id") @db.Uuid
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  ownerUser        User        @relation("ContractOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  createdByUser    User        @relation("ContractCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  activatedByUser  User?       @relation("ContractActivatedBy", fields: [activatedByUserId], references: [id], onDelete: SetNull)
  terminatedByUser User?       @relation("ContractTerminatedBy", fields: [terminatedByUserId], references: [id], onDelete: SetNull)
  closedByUser     User?       @relation("ContractClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  department       Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  plant            Plant?      @relation(fields: [plantId], references: [id], onDelete: SetNull)
  location         Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)

  comments   ContractComment[]
  activities ContractActivity[]

  @@index([status, createdAt(sort: Desc)])
  @@index([ownerUserId, status])
  @@index([createdByUserId])
  @@index([departmentId])
  @@index([plantId])
  @@index([endDate, status])
  @@index([renewalNoticeDate, status])
  @@map("contracts")
}

model ContractComment {
  id           String   @id @default(uuid()) @db.Uuid
  contractId   String   @map("contract_id") @db.Uuid
  authorUserId String   @map("author_user_id") @db.Uuid
  body         String   @db.VarChar(5000)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)
  authorUser User     @relation("ContractCommentAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([contractId, createdAt(sort: Asc)])
  @@map("contract_comments")
}

// actorUserId has no FK — mirrors IncidentActivity; deactivating a user
// does not corrupt the contract timeline.
model ContractActivity {
  id             String          @id @default(uuid()) @db.Uuid
  contractId     String          @map("contract_id") @db.Uuid
  actorUserId    String?         @map("actor_user_id") @db.Uuid
  actorName      String?         @map("actor_name") @db.VarChar(200)
  event          String          @db.VarChar(100)
  previousStatus ContractStatus? @map("previous_status")
  newStatus      ContractStatus? @map("new_status")
  metadata       Json?           @db.JsonB
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)

  @@index([contractId, createdAt(sort: Asc)])
  @@map("contract_activities")
}

// ---------------------------------------------------------------------------
// Production Management Foundation
// Unit 13 — added 2026-07-02
//
// Status lifecycle: DRAFT → SCHEDULED → IN_PROGRESS ⇆ PAUSED → COMPLETED.
//   CANCELLED is terminal from DRAFT, SCHEDULED, IN_PROGRESS, or PAUSED.
//
// Reference numbers are PROD-YYYY-NNNNNN generated atomically via
//   ProductionSequence upsert inside the creation transaction (UTC year).
//   Sequence CHECK: last_seq BETWEEN 0 AND 999999.
//
// ProductionLine has version for optimistic concurrency on updates.
// ProductionOrder has version for optimistic concurrency on all state mutations.
//
// ProductionEntry is append-only (no update/delete). Entries may be added
//   when status = IN_PROGRESS or PAUSED. Three types:
//   OUTPUT: quantityProduced / quantityAccepted / quantityRejected
//   DOWNTIME: downtimeMinutes
//   ADJUSTMENT: adjustmentQty (positive correction / negative reject correction)
//
// Derived metrics are computed from entries, never stored.
//
// authorUserId in ProductionEntry has no FK — mirrors IncidentActivity.
// actorUserId in ProductionActivity has no FK — mirrors IncidentActivity.
//
// onDelete: Restrict on createdByUser and child history tables.
//   SetNull on nullable lifecycle user FKs.
// ---------------------------------------------------------------------------

enum ProductionOrderStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED

  @@map("production_order_status")
}

enum ProductionEntryType {
  OUTPUT
  DOWNTIME
  ADJUSTMENT

  @@map("production_entry_type")
}

model ProductionSequence {
  year    Int @id
  lastSeq Int @default(0) @map("last_seq")

  @@map("production_sequences")
}

model ProductionLine {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(32)
  name        String   @db.VarChar(200)
  description String?  @db.VarChar(500)
  plantId     String?  @map("plant_id") @db.Uuid
  locationId  String?  @map("location_id") @db.Uuid
  capacity    Int?
  isActive    Boolean  @default(true) @map("is_active")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  plant    Plant?    @relation(fields: [plantId], references: [id], onDelete: SetNull)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  productionOrders ProductionOrder[]

  @@index([isActive, plantId])
  @@map("production_lines")
}

model ProductionOrder {
  id                 String                @id @default(uuid()) @db.Uuid
  referenceNumber    String                @unique @map("reference_number") @db.VarChar(20)
  title              String                @db.VarChar(300)
  description        String?               @db.VarChar(10000)
  status             ProductionOrderStatus @default(DRAFT)
  version            Int                   @default(1)
  productionLineId   String?               @map("production_line_id") @db.Uuid
  departmentId       String?               @map("department_id") @db.Uuid
  plantId            String?               @map("plant_id") @db.Uuid
  productCode        String?               @map("product_code") @db.VarChar(100)
  productName        String?               @map("product_name") @db.VarChar(300)
  targetQuantity     Int                   @map("target_quantity")
  unit               String                @db.VarChar(50)
  scheduledStartAt   DateTime?             @map("scheduled_start_at") @db.Timestamptz(3)
  scheduledEndAt     DateTime?             @map("scheduled_end_at") @db.Timestamptz(3)
  startedAt          DateTime?             @map("started_at") @db.Timestamptz(3)
  startedByUserId    String?               @map("started_by_user_id") @db.Uuid
  pausedAt           DateTime?             @map("paused_at") @db.Timestamptz(3)
  pausedByUserId     String?               @map("paused_by_user_id") @db.Uuid
  pauseReason        String?               @map("pause_reason") @db.VarChar(1000)
  resumedAt          DateTime?             @map("resumed_at") @db.Timestamptz(3)
  resumedByUserId    String?               @map("resumed_by_user_id") @db.Uuid
  completedAt        DateTime?             @map("completed_at") @db.Timestamptz(3)
  completedByUserId  String?               @map("completed_by_user_id") @db.Uuid
  completionNote     String?               @map("completion_note") @db.VarChar(4000)
  cancelledAt        DateTime?             @map("cancelled_at") @db.Timestamptz(3)
  cancelledByUserId  String?               @map("cancelled_by_user_id") @db.Uuid
  cancellationReason String?               @map("cancellation_reason") @db.VarChar(1000)
  supervisorUserId   String?               @map("supervisor_user_id") @db.Uuid
  createdByUserId    String                @map("created_by_user_id") @db.Uuid
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  productionLine  ProductionLine? @relation(fields: [productionLineId], references: [id], onDelete: SetNull)
  department      Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  plant           Plant?          @relation(fields: [plantId], references: [id], onDelete: SetNull)
  createdByUser   User            @relation("ProdOrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  supervisorUser  User?           @relation("ProdOrderSupervisor", fields: [supervisorUserId], references: [id], onDelete: SetNull)
  startedByUser   User?           @relation("ProdOrderStartedBy", fields: [startedByUserId], references: [id], onDelete: SetNull)
  pausedByUser    User?           @relation("ProdOrderPausedBy", fields: [pausedByUserId], references: [id], onDelete: SetNull)
  resumedByUser   User?           @relation("ProdOrderResumedBy", fields: [resumedByUserId], references: [id], onDelete: SetNull)
  completedByUser User?           @relation("ProdOrderCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  cancelledByUser User?           @relation("ProdOrderCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)

  entries    ProductionEntry[]
  comments   ProductionComment[]
  activities ProductionActivity[]

  @@index([status, createdAt(sort: Desc)])
  @@index([productionLineId, status])
  @@index([departmentId])
  @@index([plantId])
  @@index([createdByUserId])
  @@index([supervisorUserId, status])
  @@index([scheduledStartAt])
  @@map("production_orders")
}

// authorUserId has no FK — mirrors IncidentActivity; history preserved if user deactivated.
model ProductionEntry {
  id               String              @id @default(uuid()) @db.Uuid
  orderId          String              @map("order_id") @db.Uuid
  type             ProductionEntryType
  authorUserId     String              @map("author_user_id") @db.Uuid
  authorName       String              @map("author_name") @db.VarChar(200)
  quantityProduced Int?                @map("quantity_produced")
  quantityAccepted Int?                @map("quantity_accepted")
  quantityRejected Int?                @map("quantity_rejected")
  downtimeMinutes  Int?                @map("downtime_minutes")
  adjustmentQty    Int?                @map("adjustment_qty")
  note             String?             @db.VarChar(2000)
  recordedAt       DateTime            @map("recorded_at") @db.Timestamptz(3)
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)

  order ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt(sort: Asc)])
  @@index([orderId, type])
  @@map("production_entries")
}

model ProductionComment {
  id           String   @id @default(uuid()) @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  authorUserId String   @map("author_user_id") @db.Uuid
  body         String   @db.VarChar(5000)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  order      ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)
  authorUser User            @relation("ProdCommentAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt(sort: Asc)])
  @@map("production_comments")
}

// actorUserId has no FK — mirrors IncidentActivity; deactivating a user
// does not corrupt the production order timeline.
model ProductionActivity {
  id             String                 @id @default(uuid()) @db.Uuid
  orderId        String                 @map("order_id") @db.Uuid
  actorUserId    String?                @map("actor_user_id") @db.Uuid
  actorName      String?                @map("actor_name") @db.VarChar(200)
  event          String                 @db.VarChar(100)
  previousStatus ProductionOrderStatus? @map("previous_status")
  newStatus      ProductionOrderStatus? @map("new_status")
  metadata       Json?                  @db.JsonB
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)

  order ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt(sort: Asc)])
  @@map("production_activities")
}
